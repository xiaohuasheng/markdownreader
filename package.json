{
  "name": "markdown-reader",
  "version": "0.1.2",
  "description": "A lightweight Electron Markdown reader MVP for macOS.",
  "main": "out/main/main.js",
  "author": "Markdown Reader contributors",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:mac": "npm run build && electron-builder --mac",
    "test": "node --test tests/*.test.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "dompurify": "^3.3.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.15.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  },
  "build": {
    "appId": "com.example.markdownreader",
    "productName": "Markdown Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": [
          "html",
          "htm"
        ],
        "name": "HTML Document",
        "description": "Read-only HTML document",
        "mimeType": "text/html",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
